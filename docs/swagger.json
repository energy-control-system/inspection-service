{
    "swagger": "2.0",
    "info": {
        "description": "API for managing inspections, photos, and inspection completion.",
        "title": "Inspection Service API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api/inspection-service",
    "paths": {
        "/inspections": {
            "get": {
                "description": "Returns all inspections.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "inspections"
                ],
                "summary": "List inspections",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/inspection-service_service_inspection.Inspection"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/inspections/task/{taskID}": {
            "get": {
                "description": "Returns an inspection linked to a task.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "inspections"
                ],
                "summary": "Get inspection by task ID",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Task ID",
                        "name": "taskID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inspection-service_service_inspection.Inspection"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/inspections/{id}/finish": {
            "patch": {
                "description": "Saves inspection results, generated data, and completion state.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "inspections"
                ],
                "summary": "Finish inspection",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Inspection ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Inspection completion payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/inspection-service_service_inspection.FinishInspectionRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inspection-service_service_inspection.Inspection"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/inspections/{id}/photo": {
            "post": {
                "description": "Uploads one device or seal photo and attaches it to an inspection.",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "inspections"
                ],
                "summary": "Attach inspection photo",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Inspection ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "Inspection photo",
                        "name": "Photo",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Attachment type: 1=device photo, 2=seal photo",
                        "name": "AttachmentType",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Device ID, required when AttachmentType is 1",
                        "name": "DeviceID",
                        "in": "formData"
                    },
                    {
                        "type": "integer",
                        "description": "Seal ID, required when AttachmentType is 2",
                        "name": "SealID",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/inspection-service_service_inspection.Attachment"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/gorouter.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
